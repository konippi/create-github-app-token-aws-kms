{
  "name": "create-github-app-token-aws-kms",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "GitHub Action for creating a GitHub App installation access token using AWS KMS for JWT signing",
  "scripts": {
    "build": "esbuild src/main.ts --bundle --platform=node --target=node24 --outfile=dist/main/index.cjs && esbuild src/post.ts --bundle --platform=node --target=node24 --outfile=dist/post/index.cjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "check": "biome check . && pnpm run typecheck && pnpm run test"
  },
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "license": "MIT",
  "dependencies": {
    "@actions/core": "3.0.0",
    "@aws-sdk/client-kms": "3.1023.0",
    "@octokit/auth-app": "8.2.0",
    "@octokit/rest": "22.0.1"
  },
  "pnpm": {
    "overrides": {
      "vite": ">=8.0.5"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@types/node": "24.12.2",
    "@vitest/coverage-v8": "4.1.2",
    "aws-sdk-client-mock": "4.1.0",
    "esbuild": "0.28.0",
    "typescript": "6.0.2",
    "vitest": "4.1.2"
  }
}
